# Cloudflare AI Gateway (proxies both Anthropic and OpenAI)
CLOUDFLARE_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/YOUR_GATEWAY_NAME

# API keys (still required - Cloudflare forwards them to providers)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Supabase Postgres (with pgvector enabled)
POSTGRES_DSN=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# TranscriptAPI for YouTube transcripts
TRANSCRIPT_API_KEY=...

# Optional model overrides
CLAUDE_LEAD_MODEL=claude-opus-4-6
CLAUDE_MODEL=claude-sonnet-4-6
EMBED_MODEL=text-embedding-3-small
