# Cloudflare AI Gateway (proxies both Anthropic and OpenAI)
# Store your Anthropic and OpenAI API keys as credentials in the Cloudflare dashboard
# — no need to set them here.
CLOUDFLARE_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/YOUR_GATEWAY_NAME
CLOUDFLARE_GATEWAY_TOKEN=your-gateway-token

# Postgres — on Railway, set this to the reference variable:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# TranscriptAPI for YouTube transcripts
TRANSCRIPT_API_KEY=...

# Optional model overrides
CLAUDE_LEAD_MODEL=claude-opus-4-6
CLAUDE_MODEL=claude-sonnet-4-6
EMBED_MODEL=text-embedding-3-small
