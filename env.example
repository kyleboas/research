# Cloudflare AI Gateway
CLOUDFLARE_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_name}/openai
CLOUDFLARE_GATEWAY_TOKEN=your-cloudflare-ai-gateway-token
# You may also set a compat chat endpoint such as:
# CLOUDFLARE_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_name}/compat/chat/completions
# The app will normalize chat/embeddings routes to avoid malformed URLs.

# Postgres — on Railway, set one of these reference variables:
#   DATABASE_URL=${{pgvector.DATABASE_URL}}
#   DATABASE_PRIVATE_URL=${{pgvector.DATABASE_PRIVATE_URL}}
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# NewsBlur for RSS feed ingestion
NEWSBLUR_USERNAME=your-newsblur-username
NEWSBLUR_PASSWORD=your-newsblur-password

# TranscriptAPI for YouTube transcripts
TRANSCRIPT_API_KEY=...

# Optional provider API keys for compat-routed models.
# Use these when Cloudflare AI Gateway is not fully brokering provider auth.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Optional model overrides (defaults come from config.json)
# Use exact provider-prefixed IDs; the app no longer rewrites aliases at runtime.
LEAD_MODEL=deepseek/deepseek-r1
MODEL=workers-ai/@cf/meta/llama-3.3-70b-instruct-fp8-fast
EMBED_MODEL=openai/text-embedding-3-small
SUMMARY_MODEL=anthropic/claude-sonnet-4-6
SYNTHESIS_MODEL=anthropic/claude-sonnet-4-6
REVISION_MODEL=anthropic/claude-sonnet-4-6

# For /compat routes, use provider-prefixed models (example above).
# For /openai routes, use OpenAI model names (for example: text-embedding-3-small).
