# Cloudflare AI Gateway (proxies Anthropic; OpenAI is bypassed when ChatGPT OAuth is active)
# Store your Anthropic API key as a credential in the Cloudflare dashboard.
CLOUDFLARE_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/YOUR_GATEWAY_NAME
CLOUDFLARE_GATEWAY_TOKEN=your-gateway-token

# ChatGPT subscription OAuth — run once to authenticate:
#   python main.py --login
# Credentials are stored at ~/.codex/auth.json and refreshed automatically.
# If no OAuth credentials are found, the pipeline falls back to the gateway +
# OPENAI_API_KEY for embeddings.
# OPENAI_API_KEY=sk-...  # only needed for the gateway fallback

# Postgres — on Railway, set one of these reference variables:
#   DATABASE_URL=${{pgvector.DATABASE_URL}}
#   DATABASE_PRIVATE_URL=${{pgvector.DATABASE_PRIVATE_URL}}
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# TranscriptAPI for YouTube transcripts
TRANSCRIPT_API_KEY=...

# Optional model overrides
CLAUDE_LEAD_MODEL=claude-opus-4-6
CLAUDE_MODEL=claude-sonnet-4-6
EMBED_MODEL=text-embedding-3-small
